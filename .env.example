# Copy to .env.local and fill in with YOUR OWN values.
# (.env.local is gitignored — never commit real keys.)

# --- Supabase (required for forms to save) --------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Resend (optional — emails are skipped if unset) ----------------------
# https://resend.com → API Keys
RESEND_API_KEY=
# Verified sender, e.g. "EI Conversion <hello@eiconversion.com>"
RESEND_FROM=
# Where application notifications are sent (defaults to siteConfig.email)
APPLICATIONS_TO=
